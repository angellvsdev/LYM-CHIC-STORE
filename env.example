# Variables de Entorno - L&M CHIC Store
# Configuración para Producción con Resend

# API Key de Resend (obtener de https://resend.com/dashboard)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Email de envío (domio temporal gratuito de Resend)
RESEND_FROM_EMAIL=noreply@lymchicstore.onrender.com

# URL del frontend (producción)
FRONTEND_URL=https://lymchicstore.onrender.com

# Email de administración (Gmail)
BUSINESS_EMAIL=lymchicstore@gmail.com

# Configuración futura (cuando tengas dominio propio)
# RESEND_FROM_EMAIL=noreply@lymchicstore.com
# FRONTEND_URL=https://lymchicstore.com

# Configuración de base de datos
DATABASE_URL=postgresql://user:password@host:port/database

# Secreto para Next.js
NEXTAUTH_SECRET=tu_secreto_aqui

# Configuración de Vercel (automática)
VERCEL_ENV=production
